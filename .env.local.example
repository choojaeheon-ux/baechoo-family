# 개인 Supabase 프로젝트 키 (회사 계정 아님!)
# 값을 채우면 클라우드 동기화 모드, 비워두면 이 기기 localStorage 모드로 동작합니다.
# 이 파일을 복사해서 .env.local 로 저장하고 값을 채우세요.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 네이버 지도 JS v3 Client ID (NCP 콘솔 > Maps 애플리케이션)
# 산책 탭 지도용. 키에 사용 도메인(localhost, Vercel 도메인)을 등록해야 동작합니다.
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
